{
  "name": "pre-commit-readme-enforcer",
  "version": "1.2.0",
  "description": "Pre-commit hook: stage nearest READMEs with code changes; optional root README reachability over relative Markdown links",
  "repository": {
    "type": "git",
    "url": "https://github.com/taidaid/pre-commit-readme-enforcer.git"
  },
  "homepage": "https://github.com/taidaid/pre-commit-readme-enforcer",
  "bugs": {
    "url": "https://github.com/taidaid/pre-commit-readme-enforcer/issues"
  },
  "main": "check-readme-updated.js",
  "bin": {
    "check-readme-updated": "./check-readme-updated.js"
  },
  "scripts": {
    "build": "tsc check-readme-updated.ts --outDir . --target ES2020 --module CommonJS",
    "start": "node check-readme-updated.js",
    "dev": "ts-node check-readme-updated.ts",
    "test": "npm run build && node --test test/readme-reachability.test.cjs && node --test test/staged-readme.test.cjs && node check-readme-updated.js",
    "setup": "npm install && npm run build && npx husky",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "files": [
    "check-readme-updated.js",
    ".pre-commit-hooks.yaml",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "pre-commit",
    "readme",
    "documentation",
    "readme-links",
    "husky",
    "hook"
  ],
  "author": "Bryan Windsor",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
